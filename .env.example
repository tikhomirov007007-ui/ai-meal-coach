# Telegram
BOT_TOKEN=your_bot_token_from_botfather
WEBHOOK_SECRET=random_secret_string_min_16_chars
SETUP_SECRET=another_random_secret_for_setup
CRON_SECRET=cron_random_secret

# OpenAI
OPENAI_API_KEY=sk-...

# Database (Neon / Supabase / Vercel Postgres)
DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# Optional — Vercel sets VERCEL_URL automatically
# WEBHOOK_URL=https://your-app.vercel.app
# MINI_APP_URL=https://your-app.vercel.app/mini-app

# Local dev only
# DEV_MODE=true
# SKIP_BOT=true

# Premium pricing (Telegram Stars)
PREMIUM_WEEKLY_STARS=99
PREMIUM_MONTHLY_STARS=299
FREE_DAILY_PHOTOS=3
